# OpenAI — used to generate Cypher queries and synthesize answers
OPENAI_API_KEY=sk-...

# Neo4j AuraDB — free tier at https://neo4j.com/cloud/aura/
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# TMDB API — free key at https://www.themoviedb.org/settings/api
# Required to run seed/load_tmdb.py and populate the graph
TMDB_API_KEY=your-tmdb-key
